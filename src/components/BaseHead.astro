---
import { ClientRouter } from "astro:transitions"
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../styles/reset.scss"
import "../styles/global.scss"
import "../styles/fonts.scss"

interface Props {
	title: string
	description: string
}

const { title, description } = Astro.props
---

<meta charset="utf-8" />
<title>{title}</title>
<meta name="description" content={description} />

{/* Preload the fonts needed for above-the-fold first paint so the real
   typefaces are ready within font-display: fallback's swap window, rather
   than rendering in the fallback and swapping later. crossorigin is
   required even same-origin — fonts are fetched in CORS mode, and without
   it the preload wouldn't match the actual request (double download). */}
<link
	rel="preload"
	as="font"
	type="font/woff2"
	href="/fonts/Izoard-Regular.woff2"
	crossorigin
/>
<link
	rel="preload"
	as="font"
	type="font/woff2"
	href="/fonts/Supreme-Variable.woff2"
	crossorigin
/>
<link
	rel="preload"
	as="font"
	type="font/woff2"
	href="/fonts/IBMPlexSerif-Regular.woff2"
	crossorigin
/>

<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#2b5797" />

<meta name="msapplication-TileColor" content="#2b5797" />

<meta
	name="theme-color"
	content="#E9EBEF"
	media="(prefers-color-scheme: light)"
/>
<meta
	name="theme-color"
	content="#1D1F23"
	media="(prefers-color-scheme: dark)"
/>

<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta
	name="google-site-verification"
	content="c-0_GIsBdbjMxa6c8zqKnVYWN9oOBo743cJEGG6fgp8"
/>

<style is:inline is:global>
	:root {
		color-scheme: light dark;

		--font-izoard: Izoard, Izoard Fallback;
		--font-plex-serif: IBM Plex Serif, IBM Plex Serif Fallback;
		--font-supreme: Supreme, Supreme Fallback;
		--font-berkeley-mono: Berkeley Mono, monospace;

		--color-page-background: light-dark(
			oklch(0.82 0.008 264),
			oklch(0.22 0.010 264)
		);

		--color-background: light-dark(
			oklch(0.96 0.006 264),
			oklch(0.17 0.009 264)
		);
		--color-background-offset-close: light-dark(
			oklch(0.94 0.007 264),
			oklch(0.20 0.009 264)
		);
		--color-background-offset: light-dark(
			oklch(0.92 0.008 264),
			oklch(0.22 0.010 264)
		);
		--color-background-offset-far: light-dark(
			oklch(0.90 0.009 264),
			oklch(0.25 0.010 264)
		);
		--color-background-offset-further: light-dark(
			oklch(0.88 0.010 264),
			oklch(0.28 0.010 264)
		);
		--color-background-offset-furthest: light-dark(
			oklch(0.86 0.010 264),
			oklch(0.31 0.010 264)
		);

		// Peak colour of the header drop shadow. Black reads fine over the
		// light background, but on the dark background it needs a much
		// higher alpha to stay perceptible.
		--color-boxshadow: light-dark(oklch(0 0 0 / 0.22), oklch(0 0 0 / 0.6));

		--color-foreground: light-dark(
			oklch(0.17 0.012 264),
			oklch(0.92 0.008 264)
		);
		--color-foreground-emphasis: light-dark(
			oklch(0 0 0),
			oklch(1 0 0)
		);
		--color-foreground-medium: light-dark(
			oklch(0.47 0.026 264),
			oklch(0.70 0.006 264)
		);
		--color-foreground-light: light-dark(
			oklch(0.60 0.023 264),
			oklch(0.46 0.007 264)
		);

		--color-highlight-intense: light-dark(
			oklch(0.42 0.145 264),
			oklch(0.67 0.241 354)
		);
		--color-highlight-medium: light-dark(
			oklch(0.42 0.145 264),
			oklch(0.59 0.228 354)
		);
		--color-highlight-focus: light-dark(
			oklch(0.42 0.145 264 / 10%),
			oklch(0.67 0.241 354 / 10%)
		);

		--color-text-selection: light-dark(
			oklch(0.88 0.077 264),
			oklch(0.51 0.208 354)
		);

		--font-text: var(--font-supreme);
		--font-headline: var(--font-izoard);
		--font-description: var(--font-plex-serif);
		--font-navigation: var(--font-izoard);
		--font-ui-label: var(--font-izoard);

		--font-article-title: var(--font-plex-serif);
		--font-article-metadata: var(--font-izoard);
		--font-article-text: var(--font-supreme);

		--font-settings: var(--font-izoard);

		--page-padding: 30px;
		--content-width: 600px;
		--base-font-size: 16px;
	}

	.light-theme {
		color-scheme: light;
	}

	.dark-theme {
		color-scheme: dark;
	}

	::selection {
		background-color: var(--color-text-selection);
	}

	html {
		box-sizing: border-box;
		background-color: var(--color-background-offset-close);
		color: var(--color-foreground);
		scrollbar-gutter: stable;
		transition: background-color linear 200ms;
		-webkit-tap-highlight-color: transparent;
	}

	html:after {
		content: "";

		position: fixed;

		z-index: -1;

		bottom: -25vh;
		left: 0;
		right: 0;

		height: 50vh;
	}

	/* Ensure overscroll looks neat */
	@media screen and (max-width: 1049px) {
		html:after {
			background: var(--color-background-offset-close);
		}
	}

	@media screen and (min-width: 1050px) {
		html:after {
			background: var(--color-background);
		}
	}
</style>

<ClientRouter fallback="swap" />
