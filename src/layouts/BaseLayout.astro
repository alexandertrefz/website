---
import BaseHead from "@components/BaseHead.astro"
import Header from "@components/Header.astro"
import Footer from "@components/Footer.astro"

export interface Props {
	title: string
	description: string
}

const { title, description } = Astro.props
---

<!doctype html>
<html lang="en" style="--alignment: left; --base-font-size: 16px;">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<div id="page-container">
			<div id="container">
				<Header />

				<main>
					<div class="content">
						<slot />
					</div>
					<Footer />
				</main>
				<div id="stuck-top" aria-hidden="true">
					<div id="blur"></div>
				</div>
			</div>
		</div>

		<style lang="scss">
			#page-container {
				display: grid;

				justify-items: center;

				background-color: var(--color-background-offset);

				transition: background-color 200ms linear;
			}

			#container {
				display: grid;
				grid-template-areas:
					"header"
					"content";
				grid-template-rows: max-content 1fr;

				min-height: 100dvh;

				margin-top: env(safe-area-inset-top, 0px);
				margin-right: env(safe-area-inset-right, 0px);
				margin-bottom: env(safe-area-inset-bottom, 0px);
				margin-left: env(safe-area-inset-left, 0px);

				background-color: var(--color-background);

				position: relative;

				color: var(--color-foreground);
				min-width: 320px;
				width: 100%;

				transition: background-color 200ms linear;

				:global(#headerContainer) {
					grid-area: header;
					position: sticky;
					top: 0;
					z-index: 2;
				}

				main {
					grid-area: content;
				}

				#stuck-top {
					position: fixed;
					top: 0;
					left: 0;
					right: 0;
					z-index: 1;

					pointer-events: none;
					user-select: none;

					> #blur {
						position: relative;
						width: 100%;

						opacity: var(--scroll-shadow-opacity, 0);

						// Solid background layer: opaque behind the header,
						// then easing smoothly to transparent so the content
						// scrolling underneath dissolves into the page rather
						// than being clipped by a hard line at the header edge.
						&::before {
							content: "";
							position: absolute;
							top: 0;
							left: 0;
							right: 0;
							height: calc(var(--header-height, 90px) + 60px);
							background: var(--color-background);
							mask-image: linear-gradient(
								to bottom,
								#000 var(--header-height, 90px),
								rgba(0, 0, 0, 0.92)
									calc(var(--header-height, 90px) + 8px),
								rgba(0, 0, 0, 0.65)
									calc(var(--header-height, 90px) + 20px),
								rgba(0, 0, 0, 0.32)
									calc(var(--header-height, 90px) + 38px),
								rgba(0, 0, 0, 0.1)
									calc(var(--header-height, 90px) + 50px),
								transparent
									calc(var(--header-height, 90px) + 60px)
							);
						}

						// Frosted blur layer, masked with the same easing so
						// the blur trails off in step with the background fade.
						&::after {
							content: "";
							position: absolute;
							top: 0;
							left: 0;
							right: 0;
							height: calc(var(--header-height, 90px) + 60px);
							background-color: oklch(
								from var(--color-background) l c h / 75%
							);

							backdrop-filter: blur(5px);

							mask-image: linear-gradient(
								to bottom,
								#000 var(--header-height, 90px),
								rgba(0, 0, 0, 0.7)
									calc(var(--header-height, 90px) + 8px),
								rgba(0, 0, 0, 0.42)
									calc(var(--header-height, 90px) + 20px),
								rgba(0, 0, 0, 0.2)
									calc(var(--header-height, 90px) + 38px),
								rgba(0, 0, 0, 0.06)
									calc(var(--header-height, 90px) + 50px),
								transparent
									calc(var(--header-height, 90px) + 60px)
							);
						}
					}
				}
			}

			main {
				display: grid;
				grid-auto-rows: 1fr max-content;

				background-color: var(--color-background);

				.content {
					display: grid;
					grid-auto-rows: max-content;
					transition:
						padding 100ms linear,
						background-color 200ms linear;
				}
			}

			main :global(a) {
				position: relative;
				display: inline-block;
				font-weight: 500;
				color: var(--color-highlight-intense);
				text-decoration-color: transparent;

				transition: text-decoration-color 200ms linear;
			}

			main :global(a):hover {
				text-decoration-color: var(--color-highlight-intense);
			}

			main :global(a)::before {
				content: "";
				opacity: 0;
				pointer-events: none;
				position: absolute;
				inset: -3px -6px;
				border-radius: 3px;
				border: 1px solid var(--color-highlight-intense);
				background: var(--color-highlight-focus);
				transition: opacity linear 200ms;
			}

			main :global(a):focus-visible {
				position: relative;
				outline: none;
				box-shadow: none;
			}

			main :global(a):focus-visible::before {
				opacity: 1;
			}

			@media screen and (max-width: 399px) {
				main .content {
					padding: 20px;
					padding-top: 30px;
					padding-bottom: 0px;
				}
			}

			@media screen and (min-width: 400px) and (max-width: 649px) {
				main .content {
					padding: 20px;
					padding-top: 30px;
					padding-bottom: 0px;
				}
			}

			@media screen and (min-width: 650px) and (max-width: 849px) {
				main .content {
					padding-top: 30px;
					padding-left: 30px;
					padding-right: 30px;
					padding-bottom: 0px;
				}
			}

			@media screen and (min-width: 850px) {
				main .content {
					padding-top: 30px;
					padding-left: 30px;
					padding-right: 30px;
					padding-bottom: 0px;
				}
			}

			@media screen and (min-width: 1100px) {
				main .content {
					padding-top: 30px;
					padding-left: 30px;
					padding-right: 30px;
					padding-bottom: 0px;
				}
			}
		</style>

		<style is:inline is:global>
			html:not(.loaded) * {
				animation-duration: 0ms !important;
				transition-duration: 0ms !important;
			}

			/* Kill the default root cross-fade so it doesn't visually
			   compete with the per-element entrance animations on the
			   new page. Named transitions (title, metadata) keep their
			   own animations. */
			::view-transition-old(root),
			::view-transition-new(root) {
				animation: none;
			}

			.theme-change * {
				view-transition-name: none !important;
				animation-duration: 0ms !important;
				transition-duration: 0ms !important;
			}

			.theme-change::view-transition-new(root),
			.theme-change::view-transition-old(root) {
				animation: revert;
				transition-duration: 350ms;
			}

			/* Honour reduced-motion for cross-page navigations: swap the
			   old/new snapshots instantly instead of morphing or sliding
			   them (this covers the named title/metadata morphs too). */
			@media (prefers-reduced-motion: reduce) {
				::view-transition-group(*),
				::view-transition-old(*),
				::view-transition-new(*) {
					animation: none !important;
				}
			}
		</style>

		<script>
			requestAnimationFrame(() => {
				requestAnimationFrame(() => {
					document.documentElement.classList.add("loaded")
				})
			})

			// Track view-transition navigations globally so that per-page
			// scripts (which are only attached *after* the swap and would
			// miss the event for the very navigation that brought them
			// in) can still know whether the current page-load came from
			// a VT, and wait for that VT to finish.
			const vtState: {
				navigation: boolean
				finished: Promise<unknown> | null
			} = {
				navigation: false,
				finished: null,
			}
			;(window as any).__articleVT = vtState

			document.addEventListener("astro:before-preparation", () => {
				vtState.navigation = true
				vtState.finished = null
			})

			// `viewTransition` is only exposed on the before-swap event,
			// not before-preparation. We need its `.finished` promise to
			// know when the VT pseudo-elements are gone so we can start
			// the body stagger without running it invisibly during VT.
			document.addEventListener("astro:before-swap", (event: any) => {
				vtState.finished = event?.viewTransition?.finished ?? null
			})

			document.addEventListener("astro:after-swap", () => {
				if (vtState.navigation) {
					document.querySelector("article")?.classList.add("vt-nav")
				}
			})

			let headerResizeObserver: ResizeObserver | null = null

			const setHeaderHeightVar = (header: HTMLElement) => {
				document.documentElement.style.setProperty(
					"--header-height",
					`${header.offsetHeight}px`,
				)
			}

			const setupHeaderHeightTracking = () => {
				headerResizeObserver?.disconnect()

				const header = document.querySelector<HTMLElement>("header")
				if (!header) return

				headerResizeObserver = new ResizeObserver(() =>
					setHeaderHeightVar(header),
				)
				headerResizeObserver.observe(header)
				setHeaderHeightVar(header)
			}

			// Sync measurement on initial parse to avoid a layout flash
			// before astro:page-load fires.
			const initialHeader = document.querySelector<HTMLElement>("header")
			if (initialHeader) setHeaderHeightVar(initialHeader)

			document.addEventListener(
				"astro:page-load",
				setupHeaderHeightTracking,
			)

			const FADE_DISTANCE = 120
			let scrollShadowTicking = false

			const updateScrollShadow = () => {
				const progress = Math.min(window.scrollY / FADE_DISTANCE, 0.8)
				// Set on the root so both the header's drop shadow and the
				// content fade-out overlay can read the same value.
				document.documentElement.style.setProperty(
					"--scroll-shadow-opacity",
					progress.toString(),
				)
				scrollShadowTicking = false
			}

			window.addEventListener(
				"scroll",
				() => {
					if (!scrollShadowTicking) {
						requestAnimationFrame(updateScrollShadow)
						scrollShadowTicking = true
					}
				},
				{ passive: true },
			)

			document.addEventListener("astro:page-load", updateScrollShadow)
		</script>
	</body>
</html>
